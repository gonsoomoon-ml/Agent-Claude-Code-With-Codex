# ══════════════════════════════════════════════════════════════════════════
# briefing-agent 설정 카탈로그 (.env.example — 커밋됨. 실값/시크릿 금지)
#
# 사용법: 기본값과 *다르게* 할 줄만 .env 로 복사해 주석 해제한다(.env 는 gitignore).
#   .env = "이 환경의 결정 기록"(wiring + 시크릿 + 의도적 오버라이드) — 전체 사본 아님.
# ★ 기본값의 단일 소유자 = src/briefing/core/config.py — 아래 값들은 참고용 사본이다.
#   .env 에 복사하는 순간 그 값으로 동결된다(이후 코드 기본값 개선이 그 환경에 도달 못 함).
#   load_dotenv(override=True) 라 .env 가 OS 환경변수까지 이긴다는 점도 주의.
# ★ tests/test_config.py 의 불변식 테스트가 config.py ↔ 이 카탈로그의 동기화를 강제한다
#   (새 설정 키를 추가하면 여기 누락 시 테스트 실패 — 2026-06-27 이후 카탈로그 drift 재발 방지).
# 여기엔 배포-전역(deployment-global)만. per-user(프로필·skill)는 users/<id>/ 에 둔다.
# (패턴 참고: aws-samples/sample-deep-insight managed-agentcore — .env.example + 그룹핑)
# ══════════════════════════════════════════════════════════════════════════

# ── [모델 라우팅 · per-role] ────────────────────────────────────────────────
# AWS_REGION=us-east-1                # 전 스택 단일 리전(inference-profile·DDB·SES 일치 필수)
# AUTHOR_MODEL_ID=global.anthropic.claude-sonnet-4-6      # author(claude -p)에 ANTHROPIC_MODEL 로 전달
# SUPERVISOR_MODEL_ID=global.anthropic.claude-sonnet-4-6  # Strands supervisor(옵션) — 미설정 시 AUTHOR 재사용
# RELEVANCE_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0  # require_ai 사전 필터 judge(Haiku)
#   ↑ ★ 전체 inference-profile id 필수 — bare id(...claude-haiku-4-5)는 Bedrock 400 (Converse·invoke_model 공통, live 검증)
# RELEVANCE_LLM_ENABLED=1             # Haiku 판정 on. 기본 off=키워드 폴백만(로컬/테스트) — production 은 deploy_runtime 이 1 주입
# certifier(Codex) 모델은 우리 .env 가 아니라 codex 자신이 소유 → ~/.codex/config.toml
#   model_provider = "amazon-bedrock"  /  model = "openai.gpt-5.5"  (현재 설정)
#   → author=Claude ↔ certifier=GPT-5.5 = 다른 계열(decorrelation). 우리는 모델을 *기록*만, 설정 안 함.

# ── [author 하니스(claude -p) 라우팅 — 하니스가 직접 주입, .env 로 제어 안 함(기록용)] ──
# CLAUDE_CODE_USE_BEDROCK=1           # author.py(_run_claude)가 subprocess env 로 + deploy_runtime 이 컨테이너에 주입
# ENABLE_TOOL_SEARCH=false            # Bedrock tool def 선로드(Gateway MCP 사용 시 필수) — deploy_runtime 주입

# ── [스토어 backend ③] BACKEND=local(기본, AWS-free) | dynamo(프로덕션, CFN infra/ddb.yaml) ──
# BACKEND=local
# SOURCE_STORE_PATH=./.data/source_store    # local: 정본 원문(content-addressed, 사용자 간 dedup)
# CACHE_PATH=./.data/card_cache             # local: 결과 카드 캐시(같은 입력 재계산 방지)
# LEDGER_PATH=./.data/ledger                # local: 발행 원장 JSONL
# CACHE_TABLE=briefing-card-cache           # dynamo: 테이블명(CFN 스택 briefing-ddb 와 일치)
# LEDGER_TABLE=briefing-ledger
# SOURCE_TABLE=briefing-source-store
# USERS_TABLE=briefing-users
# DDB_ENDPOINT_URL=http://localhost:8000    # 값 주면 DynamoDB Local(무료 에뮬레이터); 기본 빈값=실 AWS

# ── [전달 · SES ⑤] ─────────────────────────────────────────────────────────
# SES_SENDER=briefing@yourdomain.com  # 공유 발신 주소 — verify 된 identity 필수(sandbox 는 수신자도). 실발송 배포 시 사실상 필수
#   ⚠️ @gmail.com/@amazon.com 발신은 DMARC 거부/배너 위험 → 커스텀 도메인 권장. 실값은 .env 에만.

# ── [사용자] ────────────────────────────────────────────────────────────────
# USERS_DIR=./users                   # per-user 설정 디렉토리 — users/<id>/{profile.yaml, skill.md}

# ── [① Gateway — 기본 off. 켜기 전엔 파이프라인 무영향(additive)] ─────────────
# GATEWAY_ENABLED=1                   # 켜면 fabric 이 retrieval 3도구를 Gateway(MCP) 경유로 호출
# GATEWAY_URL=https://<gateway-id>.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp   # deploy_gateway 출력
# GATEWAY_TARGET=briefing             # MCP 도구 prefix → "briefing___fetch_article"
# COGNITO_SCOPE=briefing-gw/invoke
# COGNITO_TOKEN_URL=https://<domain>.auth.us-east-1.amazoncognito.com/oauth2/token   # 로컬 client_credentials 용
# COGNITO_CLIENT_ID=<m2m-client-id>
# COGNITO_CLIENT_SECRET=<secret>      # ★ 비밀 — .env 에만(gitignore 확인됨). Runtime 은 AgentCore Identity 사용
# OAUTH_PROVIDER_NAME=<provider>      # AgentCore Identity provider — Runtime 이 비밀 없이 토큰 받는 경로

# ── [wiring — 배포 산출물. deploy 스크립트가 .env 에 자동 기록, 손으로 편집하지 않음] ──
# BRIEFING_RUNTIME_ARN=               # ← deploy_runtime (②)
# BRIEFING_RUNTIME_ID=
# BRIEFING_RUNTIME_NAME=
# BRIEFING_API_URL=                   # ← deploy_api (④)
# BRIEFING_WEBAPI_NAME=
# BRIEFING_WEBAPI_LAMBDA_NAME=
# BRIEFING_WEBAPI_LAMBDA_ROLE=
# BRIEFING_WEB_BUCKET=                # ← deploy_web (④)
# BRIEFING_WEB_URL=
# BRIEFING_CF_DIST_ID=
# BRIEFING_SCHEDULER_LAMBDA_ARN=      # ← deploy_scheduler (⑤)
# BRIEFING_SCHEDULER_LAMBDA_NAME=
# BRIEFING_SCHEDULER_LAMBDA_ROLE=
# BRIEFING_SCHEDULER_EVENTBRIDGE_ROLE=
# BRIEFING_SCHEDULER_SCHEDULE_NAME=
# BRIEFING_SENT_LOG_TABLE=

# ── [기타 — config.py 밖에서 코드가 직접 읽는 키] ────────────────────────────
# DEBUG=1                             # 파이프라인 추적(stderr) — 기본 off=zero overhead. 인라인 권장: DEBUG=1 uv run ...
#   (gate↔envelope↔certifier 경계 + claude/codex subprocess rc·ms + supervisor FlowHook — aiops _shared_debug 패턴)
# BRIEFING_DRY_RUN=1                  # ⚠️ 풋건: deploy_scheduler *재실행이 1 로 리셋* → 실발송 필요 시 복원 필수
# DEMO_USER=gonsoo                    # 스모크/데모 대상 사용자 id
# SENT_LOG_TABLE=briefing-sent-log    # 발송 감사 로그 테이블(⑤/admin 계측)
# BRIEFING_TRIALS_TABLE=briefing-trials   # 체험(double-opt-in) 상태 테이블(④)
# TRIAL_GLOBAL_CAP=50                 # 체험 전역 상한
# TRIAL_COOLDOWN_SECONDS=3600         # 같은 주소 체험 재신청 쿨다운(초)
# TRIAL_TEST_EMAILS=                  # 쿨다운/상한 우회 테스트 주소(콤마 구분; 빈값=없음)
# WEB_ORIGIN=*                        # webapi CORS 허용 origin(콤마 구분)

# TODO(배포 검증 — Deep Insight validate_required 패턴): 배포 스크립트 진입점에서 필수 키
#   fail-fast(예: deploy_scheduler 실발송 전 SES_SENDER 검증). 지금은 카탈로그+불변식 테스트까지만.
