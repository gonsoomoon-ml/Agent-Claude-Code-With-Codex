# ── briefing-agent 설정 (복사: cp .env.example .env) — .env 는 커밋 금지 ──
# 여기엔 **배포-전역(deployment-global)** 만. per-user(프로필·skill)은 users/<id>/ 에 둔다(다중 사용자).

# AWS / Bedrock
AWS_REGION=us-east-1                  # Web Search·Browser Tool 전용 리전 + inference-profile 가용성
# 모델 id 는 inference-profile prefix 권장(global./us.) — author=`claude -p` 에 ANTHROPIC_MODEL 로 전달
AUTHOR_MODEL_ID=global.anthropic.claude-sonnet-4-6
# Strands supervisor 오케스트레이터 모델 (옵션, per-role 라우팅) — 미설정 시 AUTHOR_MODEL_ID 재사용.
# SUPERVISOR_MODEL_ID=global.anthropic.claude-sonnet-4-6
# certifier(Codex) 모델은 우리 .env 가 아니라 codex 자신이 소유 → ~/.codex/config.toml
#   model_provider = "amazon-bedrock"  /  model = "openai.gpt-5.5"  (현재 설정)
#   → author=Claude(Sonnet 4.6) ↔ certifier=GPT-5.5 = 다른 계열(decorrelation). 우리는 모델을 *기록*만, 설정 안 함.

# author 하니스 = headless Claude Code(`claude -p`) on Bedrock — 스모크 검증됨 (claude 기본 설정엔 없어 호출 env 로 주입)
CLAUDE_CODE_USE_BEDROCK=1            # claude -p 를 Bedrock 로 라우팅
ENABLE_TOOL_SEARCH=false             # Bedrock가 tool def 선로드 (Gateway MCP 사용 시 필수)

# 전달 발신 신원 (공유 — 모든 사용자에게 한 From). 수신자는 per-user(users/<id>/profile.yaml).
#  · SES 에 *verify 된 identity* 여야 함 (sandbox 는 수신자도 사전 verify 필요).
#  · ⚠️ @gmail.com 발신은 Gmail DMARC 로 거부/스팸 위험 → 가능하면 *커스텀 도메인* 발신.
#  · 실제 값은 .env(gitignore)에. 여기(.example)는 플레이스홀더.
SES_SENDER=briefing@yourdomain.com

# content-addressed source-of-record store (공유 — 사용자 간 dedup)
SOURCE_STORE_PATH=./.data/source_store   # v1 로컬 파일; v1.5 = Gateway identical channel(S3/DDB)

# per-user 설정 디렉토리 — users/<id>/{profile.yaml, skill.md}
USERS_DIR=./users

# 개발/디버그 (aiops `_shared_debug` 패턴) — DEBUG=1 시 파이프라인 추적(stderr):
#   gate↔envelope↔certifier 경계 + claude -p / codex subprocess(rc·ms) + Strands supervisor FlowHook(LLM/tool·timing).
#   off(기본)=zero overhead. 인라인 권장: `DEBUG=1 uv run python scripts/e2e_smoke.py`.
# DEBUG=1
